# Apify — used to scrape TikTok/social data
# Get your API key/token: https://console.apify.com/settings/integrations
APIFY_API_KEY=your_apify_api_key_here
APIFY_API_TOKEN=your_apify_api_token_here

# Google Gemini — used for AI generation/analysis
# Get your API key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Anthropic (Claude) — used for AI generation/analysis
# Get your API key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Auth — signs session cookies and the internal pipeline-worker token.
# Generate with: openssl rand -hex 32
AUTH_SECRET=generate_a_long_random_string_here
